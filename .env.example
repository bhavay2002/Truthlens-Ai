# TruthLens AI Configuration

# Model Configuration
MODEL_NAME=roberta-base
MODEL_PATH=./models/roberta_model
MAX_LENGTH=256

# Training Configuration
BATCH_SIZE=8
EPOCHS=2
LEARNING_RATE=2e-5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Data Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Feature Engineering
TFIDF_MAX_FEATURES=5000
USE_SOURCE_FEATURES=True
USE_METADATA_FEATURES=True

# Optional: External APIs for fact-checking
FACT_CHECK_API_KEY=your_api_key_here
